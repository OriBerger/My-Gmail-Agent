# Anthropic API Key for LangChain
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail API Configuration
# Make sure you have credentials.json in the project root
# This file will be created by Google Cloud Console

# Optional: Project ID for Gmail notifications
GOOGLE_PROJECT_ID=your_google_project_id_here

# Webhook security (optional)
WEBHOOK_SECRET=your-webhook-secret-key-here

# Gmail Token (for Render deployment)
# Copy the entire content of your token.json file here
GMAIL_TOKEN_JSON={"token": "your_token_here", "refresh_token": "your_refresh_token_here", ...}